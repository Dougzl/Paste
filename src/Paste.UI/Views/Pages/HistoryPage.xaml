<UserControl
    x:Class="Paste.UI.Views.Pages.HistoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:converters="clr-namespace:Paste.UI.Converters"
    xmlns:helpers="clr-namespace:Paste.UI.Helpers"
    xmlns:models="clr-namespace:Paste.Core.Models;assembly=Paste.Core"
    xmlns:vm="clr-namespace:Paste.UI.ViewModels"
    d:DesignHeight="480"
    d:DesignWidth="1050"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Focusable="True">

    <UserControl.Resources>
        <converters:AppIconConverter x:Key="AppIconConverter" />
        <converters:ContentTypeToIconConverter x:Key="ContentTypeToIconConverter" />
        <converters:RelativeTimeConverter x:Key="RelativeTimeConverter" />
        <converters:ImagePreviewConverter x:Key="ImagePreviewConverter" />
        <converters:UrlDetectorConverter x:Key="UrlDetectorConverter" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:ContentTypeToVisibilityConverter x:Key="ContentTypeToVisibilityConverter" />
        <converters:ContentTypeToColorConverter x:Key="ContentTypeToColorConverter" />
        <converters:ContentTypeToLabelConverter x:Key="ContentTypeToLabelConverter" />
        <converters:StringToColorConverter x:Key="StringToColorConverter" />
        <helpers:BindingProxy x:Key="ViewModelProxy" Data="{Binding}" />
    </UserControl.Resources>

    <Grid Margin="12,0,12,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Top Bar: folder chips + add + settings gear -->
        <DockPanel Grid.Row="0" Margin="0,2,0,6" LastChildFill="True">
            <!-- Settings gear (far right) -->
            <Border
                DockPanel.Dock="Right"
                Padding="8,4"
                CornerRadius="14"
                Cursor="Hand"
                Background="Transparent"
                MouseLeftButtonUp="SettingsButton_Click"
                VerticalAlignment="Center"
                Margin="6,0,0,0">
                <TextBlock
                    Text="&#xE713;"
                    FontFamily="Segoe MDL2 Assets"
                    FontSize="14"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                    VerticalAlignment="Center" />
            </Border>

            <!-- Folder chips + add button (fill center) -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <ItemsControl ItemsSource="{Binding FavoriteFolders}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:FavoriteFolderViewModel}">
                            <Border
                                Margin="0,0,6,0"
                                Padding="8,4"
                                CornerRadius="14"
                                Cursor="Hand"
                                MouseLeftButtonUp="FolderChip_Click"
                                PreviewMouseLeftButtonDown="FolderChip_PreviewMouseDown"
                                MouseRightButtonUp="FolderChip_RightClick"
                                Tag="{Binding}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
                                        <Setter Property="BorderThickness" Value="1" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="Background" Value="{Binding ColorHex, Converter={StaticResource StringToColorConverter}}" />
                                                <Setter Property="BorderBrush" Value="{Binding ColorHex, Converter={StaticResource StringToColorConverter}}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Height="18">
                                    <!-- Colored circle -->
                                    <Ellipse Width="10" Height="10" Margin="0,0,5,0">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Fill" Value="{Binding ColorHex, Converter={StaticResource StringToColorConverter}}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="Fill" Value="White" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    <!-- Display name (visible when NOT editing) -->
                                    <TextBlock
                                        FontSize="12"
                                        VerticalAlignment="Center"
                                        Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="{Binding Name}" />
                                                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCompact}" Value="True">
                                                        <Setter Property="Text" Value="{Binding Initial}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="Foreground" Value="White" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <!-- Inline edit TextBox (visible when editing) -->
                                    <TextBox
                                        Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        FontSize="12"
                                        MinWidth="40"
                                        Height="18"
                                        Padding="0"
                                        Margin="0,-1,0,0"
                                        BorderThickness="0"
                                        Background="Transparent"
                                        Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                        CaretBrush="{DynamicResource TextFillColorPrimaryBrush}"
                                        VerticalAlignment="Center"
                                        VerticalContentAlignment="Center"
                                        Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}"
                                        KeyDown="FolderEditBox_KeyDown"
                                        LostFocus="FolderEditBox_LostFocus" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Add folder button -->
                <Border
                    Padding="6,4"
                    CornerRadius="14"
                    Cursor="Hand"
                    Background="Transparent"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    MouseLeftButtonUp="AddFolder_Click"
                    VerticalAlignment="Center">
                    <TextBlock Text="+" FontSize="13" FontWeight="Bold"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               VerticalAlignment="Center" HorizontalAlignment="Center" />
                </Border>
            </StackPanel>
        </DockPanel>

        <!-- Search + App filter bar (row 1, always visible) -->
        <Border
            Grid.Row="1"
            Margin="0,0,0,8"
            Padding="6,4"
            CornerRadius="20"
            Background="{DynamicResource ControlFillColorDefaultBrush}"
            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
            BorderThickness="1">
            <DockPanel>
                <!-- Search icon on the right -->
                <ui:SymbolIcon
                    DockPanel.Dock="Right"
                    Symbol="Search24"
                    FontSize="18"
                    Margin="8,0"
                    VerticalAlignment="Center"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                <!-- App filter chips -->
                <ItemsControl
                    DockPanel.Dock="Left"
                    ItemsSource="{Binding SourceAppFilters}"
                    VerticalAlignment="Center">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:SourceAppFilter}">
                            <Border
                                Margin="2,0"
                                Padding="6,3"
                                CornerRadius="12"
                                Cursor="Hand"
                                MouseLeftButtonUp="AppFilterChip_Click"
                                Tag="{Binding}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
                                        <Setter Property="BorderThickness" Value="1" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource SystemAccentColorPrimaryBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColorPrimaryBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <Image
                                        Width="14"
                                        Height="14"
                                        Margin="0,0,4,0"
                                        Source="{Binding AppPath, Converter={StaticResource AppIconConverter}}"
                                        VerticalAlignment="Center" />
                                    <TextBlock
                                        Text="{Binding AppName}"
                                        FontSize="11"
                                        Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                        VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Search text box (borderless) -->
                <TextBox
                    x:Name="SearchBox"
                    Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                    VerticalAlignment="Center"
                    Margin="6,0"
                    BorderThickness="0"
                    Background="Transparent"
                    FontSize="13"
                    VerticalContentAlignment="Center">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                            <Setter Property="CaretBrush" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                        </Style>
                    </TextBox.Style>
                </TextBox>
            </DockPanel>
        </Border>

        <!-- Horizontal Card Grid (row 2) -->
        <ListBox
            x:Name="CardList"
            Grid.Row="2"
            ItemsSource="{Binding Entries}"
            SelectedItem="{Binding SelectedEntry}"
            MouseDoubleClick="CardList_MouseDoubleClick"
            KeyDown="CardList_KeyDown"
            PreviewMouseWheel="CardList_PreviewMouseWheel"
            PreviewMouseLeftButtonDown="CardList_PreviewMouseLeftButtonDown"
            PreviewMouseMove="CardList_PreviewMouseMove"
            PreviewMouseLeftButtonUp="CardList_PreviewMouseLeftButtonUp"
            Background="Transparent"
            BorderThickness="0"
            ScrollViewer.HorizontalScrollBarVisibility="Hidden"
            ScrollViewer.VerticalScrollBarVisibility="Disabled"
            ScrollViewer.CanContentScroll="True"
            VirtualizingPanel.ScrollUnit="Pixel">

            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <VirtualizingStackPanel
                        Orientation="Horizontal"
                        IsVirtualizing="True"
                        VirtualizationMode="Standard" />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>

            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Width" Value="270" />
                    <Setter Property="Margin" Value="4" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                    <Setter Property="VerticalContentAlignment" Value="Stretch" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <ContentPresenter
                                    VerticalAlignment="Stretch"
                                    HorizontalAlignment="Stretch" />
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>

            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type models:ClipboardEntry}">
                    <Border
                        CornerRadius="8"
                        ClipToBounds="True"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                        <Border.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="添加到收藏夹">
                                    <MenuItem.ItemsSource>
                                        <Binding Path="Data.FavoriteFolders" Source="{StaticResource ViewModelProxy}" />
                                    </MenuItem.ItemsSource>
                                    <MenuItem.ItemContainerStyle>
                                        <Style TargetType="MenuItem">
                                            <Setter Property="Header" Value="{Binding Name}" />
                                            <Setter Property="Tag" Value="{Binding Id}" />
                                            <EventSetter Event="Click" Handler="AddToFolder_Click" />
                                        </Style>
                                    </MenuItem.ItemContainerStyle>
                                </MenuItem>
                                <MenuItem Header="从收藏夹移除" Click="RemoveFromFolder_Click" />
                            </ContextMenu>
                        </Border.ContextMenu>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Header Strip (colored, top rounded corners) -->
                            <Border Grid.Row="0" Padding="12,10" CornerRadius="8,8,0,0">
                                <Border.Background>
                                    <MultiBinding Converter="{StaticResource ContentTypeToColorConverter}">
                                        <Binding Path="ContentType" />
                                        <Binding Path="Content" />
                                    </MultiBinding>
                                </Border.Background>
                                <DockPanel>
                                    <Image
                                        DockPanel.Dock="Right"
                                        Width="32"
                                        Height="32"
                                        Source="{Binding SourceAppPath, Converter={StaticResource AppIconConverter}}"
                                        VerticalAlignment="Center" />
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock
                                            FontSize="15"
                                            FontWeight="Bold"
                                            Foreground="White">
                                            <TextBlock.Text>
                                                <MultiBinding Converter="{StaticResource ContentTypeToLabelConverter}">
                                                    <Binding Path="ContentType" />
                                                    <Binding Path="Content" />
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                        <TextBlock
                                            Text="{Binding CopiedAt, Converter={StaticResource RelativeTimeConverter}}"
                                            FontSize="10"
                                            Foreground="#AAFFFFFF" />
                                    </StackPanel>
                                </DockPanel>
                            </Border>

                            <!-- Body: Content Preview -->
                            <Grid Grid.Row="1" Margin="10,8" MinHeight="100">
                                <TextBlock
                                    Text="{Binding Content}"
                                    TextWrapping="Wrap"
                                    TextTrimming="CharacterEllipsis"
                                    MaxHeight="260"
                                    FontSize="12"
                                    LineHeight="18"
                                    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                    Visibility="{Binding ContentType, Converter={StaticResource ContentTypeToVisibilityConverter}, ConverterParameter=Text}" />

                                <StackPanel
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    Visibility="{Binding ContentType, Converter={StaticResource ContentTypeToVisibilityConverter}, ConverterParameter=Image}">
                                    <Image
                                        Width="240"
                                        Height="200"
                                        Source="{Binding Content, Converter={StaticResource ImagePreviewConverter}}"
                                        Stretch="Uniform"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        RenderOptions.BitmapScalingMode="HighQuality" />
                                    <TextBlock
                                        Text="{Binding Preview}"
                                        FontSize="10"
                                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                        HorizontalAlignment="Center"
                                        Margin="0,4,0,0" />
                                </StackPanel>

                                <StackPanel
                                    Visibility="{Binding ContentType, Converter={StaticResource ContentTypeToVisibilityConverter}, ConverterParameter=FilePaths}">
                                    <DockPanel Margin="0,4,0,0">
                                        <ui:SymbolIcon
                                            DockPanel.Dock="Left"
                                            Symbol="Folder24"
                                            FontSize="20"
                                            Margin="0,0,8,0"
                                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                            VerticalAlignment="Top" />
                                        <TextBlock
                                            Text="{Binding Content}"
                                            TextWrapping="Wrap"
                                            TextTrimming="CharacterEllipsis"
                                            MaxHeight="240"
                                            FontSize="12"
                                            Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                    </DockPanel>
                                </StackPanel>
                            </Grid>

                            <!-- Footer -->
                            <TextBlock
                                Grid.Row="2"
                                Margin="10,0,10,6"
                                FontSize="10"
                                Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="{Binding Content.Length, StringFormat='{}{0} 个字符'}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ContentType}" Value="{x:Static models:ClipboardContentType.Image}">
                                                <Setter Property="Text" Value="{Binding Preview}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>
