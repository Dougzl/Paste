<ui:FluentWindow
    x:Class="Paste.App.Views.Windows.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="设置"
    Width="500"
    MinWidth="500"
    MaxWidth="500"
    Height="600"
    MinHeight="600"
    MaxHeight="600"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    WindowBackdropType="Mica"
    ExtendsContentIntoTitleBar="True">

    <ui:FluentWindow.Resources>
        <SolidColorBrush x:Key="OrangeDot" Color="#FF9F43" />
        <SolidColorBrush x:Key="PurpleDot" Color="#A78BFA" />
        <Style TargetType="{x:Type Control}">
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="KeyboardNavigation.IsTabStop" Value="False" />
        </Style>

        <Style x:Key="ToggleSwitchStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Track" CornerRadius="12" Width="44" Height="24" Background="#555" Cursor="Hand">
                            <Ellipse x:Name="Thumb" Width="18" Height="18" Fill="White" Margin="3,0"
                                     HorizontalAlignment="Left" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#A78BFA" />
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Track" Property="Opacity" Value="0.9" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ThemeModeComboItemStyle" TargetType="ComboBoxItem" BasedOn="{StaticResource {x:Type ComboBoxItem}}">
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="BorderBrush" Value="Transparent" />
                    <Setter Property="BorderThickness" Value="0" />
                </Trigger>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter Property="BorderBrush" Value="Transparent" />
                    <Setter Property="BorderThickness" Value="0" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar
            Grid.Row="0"
            Title="设置"
            ShowMaximize="False"
            ShowMinimize="False"
            ShowClose="True" />

        <Grid Grid.Row="1" Margin="20,12,20,20">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>

                    <Border Background="{DynamicResource ControlFillColorSecondaryBrush}" CornerRadius="12" Padding="20,16" Margin="0,0,0,12" BorderBrush="Transparent" BorderThickness="0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Ellipse Width="10" Height="10" Fill="{StaticResource OrangeDot}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBlock Text="唤出/隐藏剪切板" FontSize="15" FontWeight="Bold"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" VerticalAlignment="Center" />
                            </StackPanel>

                            <DockPanel>
                                <TextBlock Text="快捷键" FontSize="13" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                <Border DockPanel.Dock="Left" Margin="12,0,0,0" Cursor="Hand"
                                        MouseLeftButtonUp="ResetHotkey_Click" VerticalAlignment="Center"
                                        ToolTip="重置为默认快捷键">
                                    <TextBlock Text="&#xE777;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                               Foreground="{StaticResource OrangeDot}" VerticalAlignment="Center" />
                                </Border>
                                <Border DockPanel.Dock="Right" Background="{DynamicResource ControlFillColorTertiaryBrush}" CornerRadius="16" Padding="16,6"
                                        HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <TextBox x:Name="HotkeyBox"
                                             IsReadOnly="True"
                                             FontSize="13"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                             CaretBrush="Transparent"
                                             Cursor="Hand"
                                             MinWidth="80"
                                             TextAlignment="Center"
                                             VerticalContentAlignment="Center"
                                             PreviewKeyDown="HotkeyBox_PreviewKeyDown"
                                             GotFocus="HotkeyBox_GotFocus"
                                             LostFocus="HotkeyBox_LostFocus" />
                                </Border>
                            </DockPanel>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource ControlFillColorSecondaryBrush}" CornerRadius="12" Padding="20,16" Margin="0,0,0,12" BorderBrush="Transparent" BorderThickness="0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Ellipse Width="10" Height="10" Fill="{StaticResource OrangeDot}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBlock Text="启动设置" FontSize="15" FontWeight="Bold"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" VerticalAlignment="Center" />
                            </StackPanel>

                            <DockPanel Margin="0,8,0,12">
                                <TextBlock Text="开机自动运行" FontSize="13" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                <ToggleButton x:Name="AutoRunToggle" DockPanel.Dock="Right" HorizontalAlignment="Right"
                                              Style="{StaticResource ToggleSwitchStyle}" />
                            </DockPanel>
                            <Border Height="1" Background="{DynamicResource ControlStrokeColorDefaultBrush}" />

                            <DockPanel Margin="0,12,0,12">
                                <TextBlock Text="启动时最小化到托盘" FontSize="13" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                <ToggleButton x:Name="MinimizeToTrayToggle" DockPanel.Dock="Right" HorizontalAlignment="Right"
                                              Style="{StaticResource ToggleSwitchStyle}" />
                            </DockPanel>
                            <Border Height="1" Background="{DynamicResource ControlStrokeColorDefaultBrush}" />

                            <DockPanel Margin="0,12,0,12">
                                <TextBlock Text="显示托盘图标" FontSize="13" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                <ToggleButton x:Name="ShowTrayIconToggle" DockPanel.Dock="Right" HorizontalAlignment="Right"
                                              Style="{StaticResource ToggleSwitchStyle}" />
                            </DockPanel>
                            <Border Height="1" Background="{DynamicResource ControlStrokeColorDefaultBrush}" />

                            <DockPanel Margin="0,12,0,4">
                                <TextBlock Text="主题" FontSize="13" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                <ComboBox
                                    x:Name="ThemeModeCombo"
                                    DockPanel.Dock="Right"
                                    Width="120"
                                    HorizontalAlignment="Right"
                                    SelectedValuePath="Tag"
                                    SelectionChanged="ThemeModeCombo_SelectionChanged">
                                    <ComboBoxItem Content="跟随系统" Tag="System" Style="{StaticResource ThemeModeComboItemStyle}" />
                                    <ComboBoxItem Content="浅色" Tag="Light" Style="{StaticResource ThemeModeComboItemStyle}" />
                                    <ComboBoxItem Content="深色" Tag="Dark" Style="{StaticResource ThemeModeComboItemStyle}" />
                                </ComboBox>
                            </DockPanel>
                            <Border Height="1" Background="{DynamicResource ControlStrokeColorDefaultBrush}" />

                            <DockPanel Margin="0,12,0,4">
                                <TextBlock Text="滚动速度" FontSize="13" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                <StackPanel DockPanel.Dock="Right" Width="190" HorizontalAlignment="Right">
                                    <Slider x:Name="ScrollSpeedSlider"
                                            Minimum="0.5"
                                            Maximum="10.0"
                                            TickFrequency="0.1"
                                            IsSnapToTickEnabled="True"
                                            ValueChanged="ScrollSpeedSlider_ValueChanged" />
                                    <TextBlock x:Name="ScrollSpeedValueText"
                                               Margin="0,2,0,0"
                                               FontSize="11"
                                               HorizontalAlignment="Right"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                            </DockPanel>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource ControlFillColorSecondaryBrush}" CornerRadius="12" Padding="20,16" Margin="0,0,0,12" BorderBrush="Transparent" BorderThickness="0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Ellipse Width="10" Height="10" Fill="{StaticResource OrangeDot}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBlock Text="源文件设置" FontSize="15" FontWeight="Bold"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" VerticalAlignment="Center" />
                            </StackPanel>

                            <DockPanel Margin="0,8,0,12">
                                <TextBlock Text="复制源文件" FontSize="13" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                <ToggleButton x:Name="CopySourceFilesToggle" DockPanel.Dock="Right" HorizontalAlignment="Right"
                                              Style="{StaticResource ToggleSwitchStyle}" />
                            </DockPanel>

                            <DockPanel x:Name="SourceFileMaxSizeRow" Margin="0,0,0,4" LastChildFill="False">
                                <TextBlock Text="源文件复制上限" FontSize="13" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                                    <TextBox
                                        x:Name="SourceFileMaxSizeBox"
                                        Width="72"
                                        Height="30"
                                        Padding="8,0"
                                        FontSize="13"
                                        VerticalContentAlignment="Center"
                                        TextAlignment="Right"
                                        PreviewTextInput="SourceFileMaxSizeBox_PreviewTextInput"
                                        LostFocus="SourceFileMaxSizeBox_LostFocus"
                                        KeyDown="SourceFileMaxSizeBox_KeyDown" />
                                    <TextBlock Text="M" Margin="6,0,0,0" FontSize="13" VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                </StackPanel>
                            </DockPanel>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource ControlFillColorSecondaryBrush}" CornerRadius="12" Padding="20,16,20,12" BorderBrush="Transparent" BorderThickness="0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Ellipse Width="10" Height="10" Fill="{StaticResource PurpleDot}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBlock Text="历史记录容量设置" FontSize="15" FontWeight="Bold"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}" VerticalAlignment="Center" />
                            </StackPanel>

                            <Slider x:Name="CleanupSlider"
                                    Minimum="0" Maximum="6"
                                    IsSnapToTickEnabled="True"
                                    TickFrequency="1"
                                    TickPlacement="None"
                                    ValueChanged="CleanupSlider_ValueChanged"
                                    Margin="0,4,0,4" />

                            <Grid Margin="0,4,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="天" FontSize="11" HorizontalAlignment="Center"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                <TextBlock Grid.Column="1" Text="周" FontSize="11" HorizontalAlignment="Center"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                <TextBlock Grid.Column="2" Text="月" FontSize="11" HorizontalAlignment="Center"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                <TextBlock Grid.Column="3" Text="季度" FontSize="11" HorizontalAlignment="Center"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                <TextBlock Grid.Column="4" Text="半年" FontSize="11" HorizontalAlignment="Center"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                <TextBlock Grid.Column="5" Text="年" FontSize="11" HorizontalAlignment="Center"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                <TextBlock Grid.Column="6" Text="无限制" FontSize="11" HorizontalAlignment="Center"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            </Grid>

                            <Button x:Name="ClearHistoryBtn" Click="ClearHistory_Click"
                                    Padding="16,8" HorizontalAlignment="Center" Cursor="Hand" Margin="0,12,0,0">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="Bd" Background="#E74C3C" CornerRadius="8" Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="#C0392B" />
                                                        </Trigger>
                                                        <Trigger Property="IsPressed" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="#A93226" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                                <TextBlock Text="清空历史记录" FontSize="13" Foreground="White" />
                            </Button>
                        </StackPanel>
                    </Border>

                    <TextBlock x:Name="VersionText"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0"
                               FontSize="12"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}" />

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</ui:FluentWindow>
