<ui:FluentWindow
    x:Class="Paste.App.Views.Windows.InputDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="Input"
    Width="340"
    Height="200"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner"
    WindowBackdropType="Mica"
    ExtendsContentIntoTitleBar="True">

    <Grid Margin="16,40,16,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="PromptText" Grid.Row="0" FontSize="14"
                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />

        <TextBox x:Name="InputBox" Grid.Row="2" FontSize="13" />

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Padding="16,6" Margin="0,0,8,0" Click="Cancel_Click" />
            <ui:Button Content="OK" Appearance="Primary" Padding="16,6" Click="OK_Click" />
        </StackPanel>
    </Grid>
</ui:FluentWindow>
